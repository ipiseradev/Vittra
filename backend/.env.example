# ============= APPLICATION =============
PROJECT_NAME=MediClinic - Medical Management System
APP_VERSION=2.0.0
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=False

# ============= DATABASE =============
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/mediclinic

# ============= SECURITY (CRITICAL: Change these in production!) =============
SECRET_KEY=your-secret-key-here-minimum-32-characters-long-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ============= CORS =============
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","https://yourdomain.com"]

# ============= FEATURES =============
ENABLE_AUDIT_LOGGING=True
ENABLE_2FA=False
MAX_LOGIN_ATTEMPTS=5

# ============= EMAIL NOTIFICATIONS (Optional) =============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@mediclinic.app

# ============= PAYMENT PROCESSING (Stripe) =============
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ============= PAYMENTS (Optional) =============
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ============= LLM PROVIDERS (Optional) =============
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
LLM_TIMEOUT_SECONDS=30.0
