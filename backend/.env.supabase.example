# ============= APPLICATION =============
PROJECT_NAME=MediClinic - Medical Management System
APP_VERSION=2.0.0
API_V1_PREFIX=/api/v1
ENVIRONMENT=production
DEBUG=False

# ============= DATABASE (Supabase) =============
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
# Get this from: Supabase Dashboard -> Settings -> Database -> Connection String
# Replace [PASSWORD] with your actual database password
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# ============= SECURITY (CRITICAL: Change these in production!) =============
SECRET_KEY=your-super-secret-key-minimum-32-chars-longsecure-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ============= CORS =============
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","https://yourdomain.com"]

# ============= FEATURES =============
ENABLE_AUDIT_LOGGING=True
ENABLE_2FA=False
MAX_LOGIN_ATTEMPTS=5

# ============= EMAIL NOTIFICATIONS (Optional) =============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@mediclinic.app

# ============= PAYMENT PROCESSING (Stripe) =============
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
